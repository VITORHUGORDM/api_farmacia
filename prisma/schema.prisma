// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id_usuario              Int                    @id @default(autoincrement())
  nome                    String                 @db.VarChar(150)
  email                   String                 @unique @db.VarChar(100)
  senha                   String                 @db.VarChar(255)
  tipo_usuario            TipoUsuario
  telefone                String?                @db.VarChar(20)
  data_cadastro           DateTime               @default(now())
  ativo                   Boolean                @default(true)
  ultimo_acesso           DateTime?
  
  // Relações
  pacientes               Paciente[]
  tratamentos             Tratamento[]           @relation("CriadorTratamento")
  permissoes_vinculadas   PermissaoAluno[]       @relation("PermissaoAluno")
  permissoes_vinculador   PermissaoAluno[]       @relation("CoordenadorVinculador")
  tokens_recuperacao      TokenRecuperacao[]
  auditoria               Auditoria[]

  @@map("USUARIOS")
}

enum TipoUsuario {
  COORDENADOR
  ALUNO
  PACIENTE

  @@map("tipo_usuario")
}

model Paciente {
  id_paciente             Int                    @id @default(autoincrement())
  id_usuario              Int                    @unique
  numero_identificacao    String                 @unique @db.VarChar(20)
  data_nascimento         DateTime?              @db.Date
  genero                  Genero                 @default(OUTRO)
  endereco                String?                @db.VarChar(255)
  cidade                  String?                @db.VarChar(100)
  estado                  String?                @db.VarChar(2)
  cep                     String?                @db.VarChar(10)
  historico_medico        String?                @db.Text
  alergias                String?                @db.Text
  data_registro           DateTime               @default(now())

  // Relações
  usuario                 Usuario                @relation(fields: [id_usuario], references: [id_usuario], onDelete: Restrict, onUpdate: Cascade)
  tratamentos             Tratamento[]
  adesoes                 AdesaoMedicamento[]
  notificacoes            Notificacao[]
  permissoes_alunos       PermissaoAluno[]

  @@map("PACIENTES")
}

enum Genero {
  M
  F
  OUTRO

  @@map("genero")
}

model Medicamento {
  id_medicamento          Int                    @id @default(autoincrement())
  nome_medicamento        String                 @unique @db.VarChar(150)
  principio_ativo         String?                @db.VarChar(150)
  dosagem                 String?                @db.VarChar(50)
  apresentacao            String?                @db.VarChar(100)
  fabricante              String?                @db.VarChar(100)
  lote                    String?                @db.VarChar(50)
  data_validade           DateTime?              @db.Date
  descricao               String?                @db.Text
  efeitos_colaterais      String?                @db.Text
  data_cadastro           DateTime               @default(now())
  ativo                   Boolean                @default(true)

  // Relações
  tratamentos             Tratamento[]

  @@map("MEDICAMENTOS")
}

model Farmaceutico {
  id_farmaceutico         Int                    @id @default(autoincrement())
  nome                    String                 @db.VarChar(150)
  email                   String                 @unique @db.VarChar(100)
  telefone                String?                @db.VarChar(20)
  especialidade           String?                @db.VarChar(100)
  data_cadastro           DateTime               @default(now())
  ativo                   Boolean                @default(true)

  // Relações
  tratamentos             Tratamento[]

  @@map("FARMACEUTICOS")
}

model Tratamento {
  id_tratamento           Int                    @id @default(autoincrement())
  id_paciente             Int
  id_medicamento          Int
  id_farmaceutico         Int
  id_usuario_criador      Int
  data_inicio             DateTime               @db.Date
  data_fim                DateTime?              @db.Date
  frequencia              String                 @db.VarChar(100)
  dosagem_prescrita       String?                @db.VarChar(100)
  motivo_tratamento       String?                @db.Text
  instrucoes_especiais    String?                @db.Text
  status                  StatusTratamento       @default(ATIVO)
  data_criacao            DateTime               @default(now())
  data_ultima_atualizacao DateTime               @updatedAt

  // Relações
  paciente                Paciente               @relation(fields: [id_paciente], references: [id_paciente], onDelete: Restrict, onUpdate: Cascade)
  medicamento             Medicamento            @relation(fields: [id_medicamento], references: [id_medicamento], onDelete: Restrict, onUpdate: Cascade)
  farmaceutico            Farmaceutico           @relation(fields: [id_farmaceutico], references: [id_farmaceutico], onDelete: Restrict, onUpdate: Cascade)
  usuario_criador         Usuario                @relation("CriadorTratamento", fields: [id_usuario_criador], references: [id_usuario], onDelete: Restrict, onUpdate: Cascade)
  adesoes                 AdesaoMedicamento[]
  notificacoes            Notificacao[]

  @@map("TRATAMENTOS")
  @@index([id_paciente])
  @@index([id_medicamento])
  @@index([id_farmaceutico])
  @@index([id_usuario_criador])
}

enum StatusTratamento {
  ATIVO
  PAUSADO
  FINALIZADO

  @@map("status")
}

model AdesaoMedicamento {
  id_adesao               Int                    @id @default(autoincrement())
  id_tratamento           Int
  id_paciente             Int
  data_prevista           DateTime
  data_tomada             DateTime?
  status                  StatusAdesao           @default(PENDENTE)
  observacoes             String?                @db.Text
  registrado_em           DateTime               @default(now())

  // Relações
  tratamento              Tratamento             @relation(fields: [id_tratamento], references: [id_tratamento], onDelete: Restrict, onUpdate: Cascade)
  paciente                Paciente               @relation(fields: [id_paciente], references: [id_paciente], onDelete: Restrict, onUpdate: Cascade)
  notificacoes            Notificacao[]

  @@map("ADESAO_MEDICAMENTOS")
  @@index([id_tratamento])
  @@index([id_paciente])
}

enum StatusAdesao {
  PENDENTE
  TOMADO
  PERDIDO
  ADIADO

  @@map("status_adesao")
}

model Notificacao {
  id_notificacao          Int                    @id @default(autoincrement())
  id_paciente             Int
  id_adesao               Int?
  tipo                    TipoNotificacao        @default(LEMBRETE)
  titulo                  String?                @db.VarChar(150)
  mensagem                String                 @db.Text
  data_agendada           DateTime
  data_envio              DateTime?
  lido                    Boolean                @default(false)
  canal                   CanalNotificacao       @default(SISTEMA)
  data_criacao            DateTime               @default(now())

  // Relações
  paciente                Paciente               @relation(fields: [id_paciente], references: [id_paciente], onDelete: Restrict, onUpdate: Cascade)
  adesao                  AdesaoMedicamento?     @relation(fields: [id_adesao], references: [id_adesao], onDelete: SetNull, onUpdate: Cascade)
  tratamento              Tratamento?            @relation(fields: [id_adesao], references: [id_tratamento], map: "fk_notificacao_tratamento")

  @@map("NOTIFICACOES")
  @@index([id_paciente])
  @@index([id_adesao])
}

enum TipoNotificacao {
  LEMBRETE
  ALARME
  INFORME

  @@map("tipo")
}

enum CanalNotificacao {
  EMAIL
  SMS
  PUSH
  SISTEMA

  @@map("canal")
}

model Auditoria {
  id_auditoria            Int                    @id @default(autoincrement())
  id_usuario              Int
  tabela_modificada       String?                @db.VarChar(50)
  id_registro_modificado  Int?
  tipo_operacao           TipoOperacao
  dados_anteriores        Json?
  dados_novos             Json?
  ip_address              String?                @db.VarChar(45)
  data_operacao           DateTime               @default(now())

  // Relações
  usuario                 Usuario                @relation(fields: [id_usuario], references: [id_usuario], onDelete: Restrict, onUpdate: Cascade)

  @@map("AUDITORIA")
  @@index([id_usuario])
}

enum TipoOperacao {
  INSERT
  UPDATE
  DELETE

  @@map("tipo_operacao")
}

model PermissaoAluno {
  id_permissao            Int                    @id @default(autoincrement())
  id_aluno                Int
  id_paciente             Int
  id_coordenador_vinculador Int?
  data_vinculacao         DateTime               @default(now())
  ativa                   Boolean                @default(true)

  // Relações
  aluno                   Usuario                @relation("PermissaoAluno", fields: [id_aluno], references: [id_usuario], onDelete: Restrict, onUpdate: Cascade)
  paciente                Paciente               @relation(fields: [id_paciente], references: [id_paciente], onDelete: Restrict, onUpdate: Cascade)
  coordenador             Usuario?               @relation("CoordenadorVinculador", fields: [id_coordenador_vinculador], references: [id_usuario], onDelete: SetNull, onUpdate: Cascade)

  @@unique([id_aluno, id_paciente])
  @@map("PERMISSOES_ALUNOS")
  @@index([id_paciente])
  @@index([id_coordenador_vinculador])
}

model TokenRecuperacao {
  id_token                Int                    @id @default(autoincrement())
  id_usuario              Int
  token                   String                 @unique @db.VarChar(255)
  criado_em               DateTime               @default(now())
  expira_em               DateTime
  usado_em                DateTime?
  revogado_em             DateTime?

  // Relações
  usuario                 Usuario                @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: Cascade)

  @@map("TOKENS_RECUPERACAO")
  @@index([id_usuario])
  @@index([expira_em])
}
